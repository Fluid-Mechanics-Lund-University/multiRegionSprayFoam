FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      chemistryProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

chemistryType
{
    solver            ode;
}

chemistry       on;

initialChemicalTimeStep 1e-07;

odeCoeffs
{
    solver          seulex;
    eps             0.05;
}

Prt                    Prt     [0 0 0 0 0] 0.7;
Sct                    Sct     [0 0 0 0 0] 0.7;
Pr                     Pr     [0 0 0 0 0] 1;
Sc                     Sc     [0 0 0 0 0] 1;
Cchi                   Cchi    [0 0 0 0 0] 2.0;

